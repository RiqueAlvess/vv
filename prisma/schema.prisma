// ============================================================
// Asta - Psychosocial Risk Analysis System
// Prisma Schema (Multi-Schema: core, survey, analytics)
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "survey", "analytics"]
}

// ============================================================
// SCHEMA: core
// ============================================================

model Company {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  cnpj       String   @unique @db.VarChar(18)
  cnae       String?  @db.VarChar(10)
  active     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  users           User[]
  campaigns       Campaign[]
  feedbackChannel CompanyFeedbackChannel?

  @@map("companies")
  @@schema("core")
}

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String   @db.Uuid
  name          String
  email         String   @unique
  password_hash String
  role          String   @db.VarChar(20)
  sector_id     String?  @db.Uuid
  active        Boolean   @default(true)
  last_login_at DateTime? @db.Timestamptz()
  created_at    DateTime  @default(now()) @db.Timestamptz()
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz()

  company        Company        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  refresh_tokens RefreshToken[]
  campaigns      Campaign[]     @relation("CampaignCreator")
  articles_authored Article[]   @relation("ArticleAuthor")
  notifications_created SystemNotification[]     @relation("NotificationCreator")
  notification_views    SystemNotificationView[] @relation("NotificationViews")

  @@map("users")
  @@schema("core")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  token      String   @unique
  expires_at DateTime @db.Timestamptz()
  created_at DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
  @@schema("core")
}

// ============================================================
// SCHEMA: survey
// ============================================================

model Campaign {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id    String   @db.Uuid
  name          String
  description   String?
  start_date    DateTime @db.Timestamptz()
  end_date      DateTime @db.Timestamptz()
  status        String   @default("draft") @db.VarChar(20)
  campaign_salt String
  created_by    String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz()
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz()

  company     Company          @relation(fields: [company_id], references: [id], onDelete: Cascade)
  creator     User?            @relation("CampaignCreator", fields: [created_by], references: [id], onDelete: SetNull)
  units       CampaignUnit[]
  qr_codes    CampaignQRCode[]
  responses   SurveyResponse[]
  employees   CampaignEmployee[]
  metrics     CampaignMetrics?
  facts       FactResponse[]
  dim_sectors DimSector[]
  checklist   ChecklistProgress?

  @@map("campaigns")
  @@schema("survey")
}

model CampaignUnit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id String   @db.Uuid
  name        String
  created_at  DateTime @default(now()) @db.Timestamptz()

  campaign  Campaign        @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  sectors   CampaignSector[]
  responses SurveyResponse[]

  @@map("campaign_units")
  @@schema("survey")
}

model CampaignSector {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unit_id    String   @db.Uuid
  name       String
  created_at DateTime @default(now()) @db.Timestamptz()

  unit      CampaignUnit       @relation(fields: [unit_id], references: [id], onDelete: Cascade)
  positions CampaignPosition[]
  responses SurveyResponse[]

  @@map("campaign_sectors")
  @@schema("survey")
}

model CampaignPosition {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sector_id  String   @db.Uuid
  name       String
  created_at DateTime @default(now()) @db.Timestamptz()

  sector    CampaignSector   @relation(fields: [sector_id], references: [id], onDelete: Cascade)
  responses SurveyResponse[]
  employees CampaignEmployee[]

  @@map("campaign_positions")
  @@schema("survey")
}

/// QR code for campaign — multiple codes can exist; only is_active=true are usable
model CampaignQRCode {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id    String    @db.Uuid
  token          String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now()) @db.Timestamptz()
  deactivated_at DateTime? @db.Timestamptz()

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@map("campaign_qr_codes")
  @@schema("survey")
}

/// NO FK to QR code or any identifying record — anonymity guarantee
/// CPF is validated via CampaignEmployee but never stored here (Blind-Drop)
model SurveyResponse {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id         String    @db.Uuid
  session_uuid        String    @db.Uuid
  unit_id             String?   @db.Uuid
  sector_id           String?   @db.Uuid
  position_id         String?   @db.Uuid
  gender              String?   @db.VarChar(1)
  age_range           String?   @db.VarChar(20)
  consent_accepted    Boolean   @default(true)
  consent_accepted_at DateTime? @db.Timestamptz()
  responses           Json
  created_at          DateTime  @default(now()) @db.Timestamptz()

  campaign Campaign         @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  unit     CampaignUnit?    @relation(fields: [unit_id], references: [id], onDelete: SetNull)
  sector   CampaignSector?  @relation(fields: [sector_id], references: [id], onDelete: SetNull)
  position CampaignPosition? @relation(fields: [position_id], references: [id], onDelete: SetNull)
  facts    FactResponse[]

  @@index([campaign_id])
  @@map("survey_responses")
  @@schema("survey")
}

/// One row per employee registered via CSV for this campaign.
/// cpf_hash = SHA-256(campaign_salt:cpf_digits) — nulled after survey submission.
/// validation_token = ephemeral UUID issued when CPF is verified, one-use 15-min TTL.
/// position_id = FK to CampaignPosition from CSV; used to pre-suggest hierarchy on survey.
model CampaignEmployee {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id                 String    @db.Uuid
  cpf_hash                    String?   @db.VarChar(64)
  position_id                 String?   @db.Uuid
  has_responded               Boolean   @default(false)
  validation_token            String?   @unique @db.Uuid
  validation_token_expires_at DateTime? @db.Timestamptz()
  created_at                  DateTime  @default(now()) @db.Timestamptz()

  campaign Campaign          @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  position CampaignPosition? @relation(fields: [position_id], references: [id], onDelete: SetNull)

  @@index([campaign_id, cpf_hash])
  @@map("campaign_employees")
  @@schema("survey")
}

model SurveyQuestion {
  id              Int     @id @default(autoincrement())
  question_number Int     @unique
  dimension       String  @db.VarChar(30)
  question_text   String
  active          Boolean @default(true)

  @@map("survey_questions")
  @@schema("survey")
}

model ChecklistProgress {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id   String   @unique @db.Uuid
  checked_items Json     @default("[]")
  updated_at    DateTime @default(now()) @db.Timestamptz()
  created_at    DateTime @default(now()) @db.Timestamptz()

  campaign  Campaign            @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  evidences ChecklistEvidence[]

  @@map("checklist_progress")
  @@schema("survey")
}

model ChecklistEvidence {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checklist_id String   @db.Uuid
  item_id      String
  file_name    String
  file_url     String
  file_type    String   @db.VarChar(50)
  uploaded_at  DateTime @default(now()) @db.Timestamptz()

  checklist ChecklistProgress @relation(fields: [checklist_id], references: [id], onDelete: Cascade)

  @@map("checklist_evidences")
  @@schema("survey")
}

// ============================================================
// SCHEMA: analytics (Star Schema)
// ============================================================

model FactResponse {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id String   @db.Uuid
  response_id String   @db.Uuid
  dimension   String   @db.VarChar(30)
  score       Decimal  @db.Decimal(4, 2)
  risk_level  String   @db.VarChar(20)
  nr_value    Decimal? @db.Decimal(5, 2)
  created_at  DateTime @default(now()) @db.Timestamptz()

  campaign Campaign       @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  response SurveyResponse @relation(fields: [response_id], references: [id], onDelete: Cascade)

  @@index([campaign_id])
  @@map("fact_responses")
  @@schema("analytics")
}

model DimSector {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id   String   @db.Uuid
  unit_name     String?
  sector_name   String?
  position_name String?
  created_at    DateTime @default(now()) @db.Timestamptz()

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@map("dim_sectors")
  @@schema("analytics")
}

model CompanyFeedbackChannel {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id   String   @unique @db.Uuid
  public_token String   @unique
  active       Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamptz()

  company   Company             @relation(fields: [company_id], references: [id], onDelete: Cascade)
  feedbacks AnonymousFeedback[]

  @@map("company_feedback_channels")
  @@schema("core")
}

model AnonymousFeedback {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel_id String   @db.Uuid
  type       String   @db.VarChar(20)
  category   String?  @db.VarChar(30)
  message    String   @db.Text
  read       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz()

  channel CompanyFeedbackChannel @relation(fields: [channel_id], references: [id], onDelete: Cascade)

  @@map("anonymous_feedbacks")
  @@schema("core")
}

model Article {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String
  slug       String   @unique
  content    String
  cover_url  String?
  pinned     Boolean  @default(false)
  published  Boolean  @default(true)
  author_id  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @db.Timestamptz()

  author User @relation("ArticleAuthor", fields: [author_id], references: [id])

  @@map("articles")
  @@schema("core")
}

model SystemLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  level       String   @db.VarChar(10)
  action      String   @db.VarChar(100)
  user_id     String?  @db.Uuid
  user_email  String?  @db.VarChar(255)
  company_id  String?  @db.Uuid
  target_id   String?  @db.Uuid
  target_type String?  @db.VarChar(50)
  message     String
  metadata    Json?
  ip          String?  @db.VarChar(50)
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([level, created_at])
  @@index([user_id, created_at])
  @@index([created_at])
  @@map("system_logs")
  @@schema("core")
}

model SystemNotification {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String
  message    String
  active     Boolean  @default(true)
  starts_at  DateTime @db.Timestamptz()
  ends_at    DateTime @db.Timestamptz()
  created_by String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz()
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz()

  creator User                     @relation("NotificationCreator", fields: [created_by], references: [id])
  views   SystemNotificationView[]

  @@map("system_notifications")
  @@schema("core")
}

model SystemNotificationView {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notification_id String   @db.Uuid
  user_id         String   @db.Uuid
  viewed_at       DateTime @default(now()) @db.Timestamptz()

  notification SystemNotification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  user         User               @relation("NotificationViews", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, user_id])
  @@map("system_notification_views")
  @@schema("core")
}

model Job {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         String    @db.VarChar(50)
  payload      Json      @default("{}")
  status       String    @default("pending") @db.VarChar(20)
  attempts     Int       @default(0)
  max_attempts Int       @default(3)
  error        String?
  run_after    DateTime  @default(now()) @db.Timestamptz()
  started_at   DateTime? @db.Timestamptz()
  completed_at DateTime? @db.Timestamptz()
  created_at   DateTime  @default(now()) @db.Timestamptz()

  @@index([status, run_after])
  @@map("jobs")
  @@schema("core")
}

model CampaignMetrics {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaign_id         String   @unique @db.Uuid
  total_employees     Int      @default(0)
  total_invited       Int      @default(0)
  total_responded     Int      @default(0)
  response_rate       Decimal  @default(0) @db.Decimal(5, 2)
  igrp                Decimal? @db.Decimal(5, 2)
  risk_distribution   Json?
  dimension_scores    Json?
  demographic_data    Json?
  heatmap_data        Json?
  top_critical_sectors Json?
  scores_by_gender    Json?
  scores_by_age       Json?
  top_critical_groups Json?
  calculated_at       DateTime? @db.Timestamptz()
  created_at          DateTime  @default(now()) @db.Timestamptz()
  updated_at          DateTime  @default(now()) @db.Timestamptz()

  campaign Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)

  @@map("campaign_metrics")
  @@schema("analytics")
}
